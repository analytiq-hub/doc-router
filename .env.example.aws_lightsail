# On AWS Lightsail, set up nginx to route http://<mydomain>/* to localhost:3000
# and http://<mydomain>/fastapi/* to localhost:8000
# Also set up SSL/TLS certs for <mydomain>
# and point MONGODB_URI to a running MongoDB instance

ENV="dev"
MONGODB_URI=mongodb://localhost:27017

# Public FastAPI URL (browser + OAuth redirects; mapped to NEXT_PUBLIC_* at Next.js build time)
PUBLIC_API_URL="https://<mydomain>/fastapi"
# FastAPI backend root path
FASTAPI_ROOT_PATH="/fastapi"

# Worker settings (queue counts live in system_settings / admin UI; default 4 per queue)
DOCROUTER_WORKERS_ENABLED=1
N_UVICORN_WORKERS=1

# Create an admin user
ADMIN_EMAIL="admin@yourcompany.com"
ADMIN_PASSWORD="admin"

# Set up API credentials for various services. 
# These can also be set up later in the GUI.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# NextJS frontend
NEXTAUTH_URL="https://<mydomain>"
NEXTAUTH_SECRET=your-nextauth-secret

# Github OAuth
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Email verification
SES_FROM_EMAIL=
