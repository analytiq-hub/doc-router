{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "resource": {
      "type": "string",
      "enum": ["message"],
      "default": "message",
      "title": "Resource",
      "x-ui-enum-names": ["Message"]
    },
    "operation": {
      "type": "string",
      "enum": ["send", "get", "getAll"],
      "default": "send",
      "title": "Operation",
      "x-ui-enum-names": ["Send", "Get", "Get Many"],
      "x-ui-show-when": {
        "field": "resource",
        "equals": "message"
      }
    },
    "sendTo": {
      "type": "string",
      "default": "",
      "title": "To",
      "description": "Recipient email addresses, comma-separated.",
      "x-ui-placeholder": "info@example.com",
      "x-ui-show-when": {
        "all": [
          { "field": "resource", "equals": "message" },
          { "field": "operation", "equals": "send" }
        ]
      }
    },
    "subject": {
      "type": "string",
      "default": "",
      "title": "Subject",
      "x-ui-show-when": {
        "all": [
          { "field": "resource", "equals": "message" },
          { "field": "operation", "equals": "send" }
        ]
      }
    },
    "emailType": {
      "type": "string",
      "enum": ["text", "html"],
      "default": "html",
      "title": "Email type",
      "x-ui-enum-names": ["Text", "HTML"],
      "x-ui-show-when": {
        "all": [
          { "field": "resource", "equals": "message" },
          { "field": "operation", "equals": "send" }
        ]
      }
    },
    "message": {
      "type": "string",
      "default": "",
      "title": "Message",
      "x-ui-widget": "textarea",
      "x-ui-show-when": {
        "all": [
          { "field": "resource", "equals": "message" },
          { "field": "operation", "equals": "send" }
        ]
      }
    },
    "options": {
      "type": "object",
      "default": {},
      "title": "Options",
      "description": "Optional send fields: ccList, bccList, replyTo, senderName (JSON object).",
      "x-ui-show-when": {
        "all": [
          { "field": "resource", "equals": "message" },
          { "field": "operation", "equals": "send" }
        ]
      }
    },
    "messageId": {
      "type": "string",
      "default": "",
      "title": "Message ID",
      "x-ui-placeholder": "172ce2c4a72cc243",
      "x-ui-show-when": {
        "all": [
          { "field": "resource", "equals": "message" },
          { "field": "operation", "equals": "get" }
        ]
      }
    },
    "simple": {
      "type": "boolean",
      "default": true,
      "title": "Simplify",
      "description": "Return metadata with flattened headers instead of the full Gmail payload.",
      "x-ui-show-when-any": [
        {
          "all": [
            { "field": "resource", "equals": "message" },
            { "field": "operation", "equals": "get" }
          ]
        },
        {
          "all": [
            { "field": "resource", "equals": "message" },
            { "field": "operation", "equals": "getAll" }
          ]
        }
      ]
    },
    "returnAll": {
      "type": "boolean",
      "default": false,
      "title": "Return all",
      "x-ui-show-when": {
        "all": [
          { "field": "resource", "equals": "message" },
          { "field": "operation", "equals": "getAll" }
        ]
      }
    },
    "limit": {
      "type": "integer",
      "default": 50,
      "minimum": 1,
      "maximum": 500,
      "title": "Limit",
      "x-ui-show-when": {
        "all": [
          { "field": "resource", "equals": "message" },
          { "field": "operation", "equals": "getAll" },
          { "field": "returnAll", "equals": false }
        ]
      }
    },
    "filters": {
      "type": "object",
      "default": {},
      "title": "Filters",
      "description": "Gmail search filters (JSON): q, sender, readStatus (unread/read/both), labelIds, includeSpamTrash, receivedAfter, receivedBefore.",
      "x-ui-show-when": {
        "all": [
          { "field": "resource", "equals": "message" },
          { "field": "operation", "equals": "getAll" }
        ]
      }
    }
  }
}
