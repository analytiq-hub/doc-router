{
  "schema": "urn:docrouter:flow-node-manifest:v1",
  "manifest_version": 1,
  "key": "flows.respond_to_tool",
  "type_version": 1,
  "label": "Respond to tool",
  "description": "Sets json.tool_result for parent flow_tool dispatch.",
  "category": "AI",
  "is_trigger": false,
  "is_merge": false,
  "min_inputs": 1,
  "max_inputs": 1,
  "outputs": 0,
  "output_labels": [],
  "icon_key": "respond_to_tool",
  "executor": {
    "kind": "python_class",
    "import": "analytiq_data.flows.nodes.respond_to_tool",
    "class": "FlowsRespondToToolNode"
  },
  "palette_group": "ai",
  "experimental": true,
  "parameter_schema": {
    "type": "object",
    "properties": {
      "result_source": {
        "type": "string",
        "enum": [
          "from_input",
          "input_field",
          "fixed"
        ],
        "default": "from_input",
        "x-ui-widget": "select"
      },
      "result_field": {
        "type": "string",
        "default": "tool_result"
      },
      "result_value": {
        "type": "object",
        "x-ui-widget": "json"
      }
    },
    "additionalProperties": false
  }
}
