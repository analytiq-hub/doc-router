      "type": "object",
      "default": {},
      "title": "Additional Fields",
      "properties": {
        "name": {
          "type": "string",
          "default": "",
          "title": "Name"
        }
      },
      "x-ui-show-when": {
        "all": [
          {"field": "resource", "equals": "file"},
          {"field": "operation", "equals": "copy"}
        ]
      }
    },
    "parentReference": {
      "type": "object",
      "default": {},
      "title": "Parent Reference",
      "properties": {
        "driveId": {"type": "string", "default": "", "title": "Drive ID"},
        "driveType": {"type": "string", "default": "", "title": "Drive Type"},
        "id": {"type": "string", "default": "", "title": "ID"},
        "listId": {"type": "string", "default": "", "title": "List ID"},
        "name": {"type": "string", "default": "", "title": "Name"},
        "path": {"type": "string", "default": "", "title": "Path"},
        "shareId": {"type": "string", "default": "", "title": "Share ID"},
        "siteId": {"type": "string", "default": "", "title": "Site ID"}
