{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "siteId": {
      "type": "string",
      "default": "root",
      "title": "Site",
      "description": "Site ID, root, hostname:/sites/Name composite, or full SharePoint site URL.",
      "x-ui-placeholder": "root or contoso.sharepoint.com:/sites/Team"
    },
    "resource": {
      "type": "string",
      "enum": ["file", "folder", "list", "site"],
      "default": "file",
      "title": "Resource",
      "x-ui-enum-names": ["File", "Folder", "List", "Site"]
    },
    "operation": {
      "type": "string",
      "default": "upload",
      "title": "Operation",
      "x-ui-enum-by": {
        "field": "resource",
        "variants": {
          "file": {
            "enum": [
              "copy",
              "delete",
              "download",
              "get",
              "rename",
              "search",
              "share",
              "upload"
            ],
            "x-ui-enum-names": [
              "Copy",
              "Delete",
              "Download",
              "Get",
              "Rename",
              "Search",
              "Share",
              "Upload"
            ]
          },
          "folder": {
            "enum": [
              "create",
              "delete",
              "getChildren",
              "rename",
              "search",
              "share"
            ],
            "x-ui-enum-names": [
              "Create",
              "Delete",
              "Get Children",
              "Rename",
              "Search",
              "Share"
            ]
          },
          "list": {
            "enum": ["get", "getItems", "getMany"],
            "x-ui-enum-names": ["Get", "Get Items", "Get Many"]
          },
          "site": {
            "enum": ["get", "search"],
            "x-ui-enum-names": ["Get", "Search"]
          }
        }
      }
    },
    "listId": {
      "type": "string",
      "default": "",
      "title": "List",
      "description": "SharePoint list ID.",
      "x-ui-show-when": {
        "all": [
          {"field": "resource", "equals": "list"}
        ]
      }
    },
    "fileId": {
      "type": "string",
      "default": "",
      "title": "File",
      "description": "Drive item ID from the site document library.",
      "x-ui-placeholder": "Drive item ID",
      "x-ui-show-when-any": [
        {
          "all": [
            {"field": "resource", "equals": "file"},
            {"field": "operation", "equals": "copy"}
          ]
        },
        {
          "all": [
            {"field": "resource", "equals": "file"},
            {"field": "operation", "equals": "delete"}
          ]
        },
        {
          "all": [
            {"field": "resource", "equals": "file"},
            {"field": "operation", "equals": "download"}
          ]
        },
        {
          "all": [
            {"field": "resource", "equals": "file"},
            {"field": "operation", "equals": "get"}
          ]
        },
        {
          "all": [
            {"field": "resource", "equals": "file"},
            {"field": "operation", "equals": "share"}
          ]
        }
      ]
    },
