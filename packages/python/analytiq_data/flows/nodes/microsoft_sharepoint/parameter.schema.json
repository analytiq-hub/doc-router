      "x-ui-show-when": {
        "all": [
          {"field": "resource", "equals": "file"},
          {"field": "operation", "equals": "copy"}
        ]
      }
    },
    "binaryPropertyName": {
      "type": "string",
      "default": "data",
      "title": "Binary Property",
      "x-ui-show-when-any": [
        {
          "all": [
            {"field": "resource", "equals": "file"},
            {"field": "operation", "equals": "download"}
          ]
        },
        {
          "all": [
            {"field": "resource", "equals": "file"},
            {"field": "operation", "equals": "upload"},
            {"field": "binaryData", "equals": true}
          ]
        }
      ]
    },
    "itemId": {
      "type": "string",
      "default": "",
      "title": "Item",
      "description": "Drive item ID from the site document library.",
      "x-ui-placeholder": "Drive item ID",
