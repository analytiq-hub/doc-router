      "x-ui-show-when-any": [
        {
          "all": [
            {"field": "resource", "equals": "folder"},
            {"field": "operation", "equals": "delete"}
          ]
        },
        {
          "all": [
            {"field": "resource", "equals": "folder"},
            {"field": "operation", "equals": "getChildren"}
          ]
        },
        {
          "all": [
            {"field": "resource", "equals": "folder"},
            {"field": "operation", "equals": "share"}
          ]
        }
      ]
    }
