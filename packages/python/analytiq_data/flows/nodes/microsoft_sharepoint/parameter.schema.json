      }
    },
    "query": {
      "type": "string",
      "default": "",
      "title": "Query",
      "x-ui-show-when": {
        "all": [
          {"field": "operation", "equals": "search"}
        ]
      }
    },
    "type": {
      "type": "string",
      "enum": ["view", "edit", "embed"],
      "default": "view",
      "title": "Type",
      "x-ui-enum-names": ["View", "Edit", "Embed"],
      "x-ui-show-when": {
        "all": [
          {"field": "operation", "equals": "share"}
        ]
      }
    },
    "scope": {
      "type": "string",
      "enum": ["anonymous", "organization"],
      "default": "anonymous",
      "title": "Scope",
      "x-ui-enum-names": ["Anonymous", "Organization"],
      "x-ui-show-when": {
        "all": [
          {"field": "operation", "equals": "share"}
        ]
      }
    },
    "parentId": {
      "type": "string",
      "default": "",
      "title": "Parent",
      "description": "Parent folder ID in the site document library.",
