      "x-ui-show-when": {
        "all": [
          {"field": "resource", "equals": "file"},
          {"field": "operation", "equals": "upload"}
        ]
      }
    },
    "fileName": {
      "type": "string",
      "default": "",
      "title": "File Name",
      "x-ui-show-when": {
        "all": [
          {"field": "resource", "equals": "file"},
          {"field": "operation", "equals": "upload"}
        ]
      }
    },
    "binaryData": {
      "type": "boolean",
      "default": true,
      "title": "Binary Data",
      "x-ui-show-when": {
        "all": [
          {"field": "resource", "equals": "file"},
          {"field": "operation", "equals": "upload"}
        ]
      }
    },
    "fileContent": {
      "type": "string",
      "default": "",
      "title": "File Content",
      "x-ui-show-when": {
        "all": [
          {"field": "resource", "equals": "file"},
          {"field": "operation", "equals": "upload"},
          {"field": "binaryData", "equals": false}
        ]
      }
    },
    "name": {
      "type": "string",
      "default": "",
      "title": "Name",
      "x-ui-show-when": {
        "all": [
          {"field": "resource", "equals": "folder"},
          {"field": "operation", "equals": "create"}
        ]
      }
    },
    "options": {
      "type": "object",
      "default": {},
      "title": "Options",
      "properties": {
        "parentFolderId": {
          "type": "string",
          "default": "",
          "title": "Parent Folder",
          "description": "Parent folder ID in the site document library."
        }
      },
      "x-ui-show-when": {
        "all": [
          {"field": "resource", "equals": "folder"},
          {"field": "operation", "equals": "create"}
        ]
      }
    },
    "folderId": {
      "type": "string",
      "default": "",
      "title": "Folder",
      "description": "Folder ID in the site document library.",
