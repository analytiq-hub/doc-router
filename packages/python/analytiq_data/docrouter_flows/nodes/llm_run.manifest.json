{
  "schema": "urn:docrouter:flow-node-manifest:v1",
  "manifest_version": 1,
  "key": "docrouter.llm_run",
  "type_version": 1,
  "label": "Run LLM",
  "description": "Runs a configured prompt on flow item data with optional OCR context.",
  "category": "DocRouter",
  "is_trigger": false,
  "is_merge": true,
  "min_inputs": 1,
  "max_inputs": 2,
  "outputs": 1,
  "output_labels": [
    "output"
  ],
  "input_port_types": [
    "main",
    "docrouter.ocr"
  ],
  "icon_key": "llm_run",
  "executor": {
    "kind": "python_class",
    "import": "analytiq_data.docrouter_flows.nodes.llm_node",
    "class": "DocRouterLlmRunNode"
  },
  "palette_group": "docrouter",
  "parameter_schema": {
    "type": "object",
    "title": "Run LLM",
    "properties": {
      "prompt_id": {
        "type": "string",
        "title": "Prompt",
        "description": "Prompt to run.",
        "x-ui-widget": "org_prompt_picker"
      }
    },
    "required": [
      "prompt_id"
    ],
    "additionalProperties": false
  }
}
