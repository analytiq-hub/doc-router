{
  "schema": "urn:docrouter:flow-node-manifest:v1",
  "manifest_version": 1,
  "key": "docrouter.ocr",
  "type_version": 1,
  "label": "Run OCR",
  "description": "Runs OCR on the input PDF and exposes per-page text for downstream nodes.",
  "category": "DocRouter",
  "is_trigger": false,
  "is_merge": false,
  "min_inputs": 1,
  "max_inputs": 1,
  "outputs": 1,
  "output_labels": [
    "output"
  ],
  "output_port_types": [
    "docrouter.ocr"
  ],
  "icon_key": "ocr",
  "executor": {
    "kind": "python_class",
    "import": "analytiq_data.docrouter_flows.nodes.ocr_node",
    "class": "DocRouterOcrNode"
  },
  "palette_group": "docrouter",
  "parameter_schema": {
    "type": "object",
    "title": "Run OCR",
    "properties": {
      "ocr_provider": {
        "type": "string",
        "enum": [
          "textract",
          "mistral",
          "pymupdf",
          "llm"
        ],
        "default": "textract",
        "description": "OCR backend to use."
      }
    },
    "required": [
      "ocr_provider"
    ],
    "additionalProperties": false
  }
}
