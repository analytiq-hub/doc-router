{
  "key": "questDb",
  "display_name": "QuestDB",
  "auth_mode": "custom",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "host": {
        "title": "Host",
        "type": "string",
        "default": "localhost"
      },
      "database": {
        "title": "Database",
        "type": "string",
        "default": "qdb"
      },
      "user": {
        "title": "User",
        "type": "string",
        "default": "admin"
      },
      "password": {
        "title": "Password",
        "type": "string",
        "x-secret": true,
        "default": "quest"
      },
      "ssl": {
        "title": "SSL",
        "type": "string",
        "enum": [
          "allow",
          "disable",
          "require"
        ],
        "default": "disable"
      },
      "port": {
        "title": "Port",
        "type": "number",
        "default": 8812
      }
    },
    "required": []
  },
  "experimental": true
}
