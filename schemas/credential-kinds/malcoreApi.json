{
  "key": "malcoreApi",
  "display_name": "MalcoreAPI",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "title": "API Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": [
      "apiKey"
    ]
  },
  "inject": {
    "headers": {
      "apiKey": "{{ credentials.apiKey }}"
    }
  },
  "test_request": {
    "method": "POST",
    "url": "https://api.malcore.io/api/urlcheck"
  },
  "experimental": true
}
