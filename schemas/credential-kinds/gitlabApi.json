{
  "key": "gitlabApi",
  "display_name": "GitLab API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "server": {
        "title": "Gitlab Server",
        "type": "string",
        "default": "https://gitlab.com"
      },
      "accessToken": {
        "title": "Access Token",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": []
  },
  "inject": {
    "headers": {
      "Private-Token": "{{ credentials.accessToken }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "={{$credentials.server.replace(new RegExp(\"/$\"), \"\") + \"/api/v4\" }}/personal_access_tokens/self"
  },
  "experimental": true
}
