{
  "key": "recordedFutureApi",
  "display_name": "Recorded Future API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "title": "Access Token",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": [
      "apiKey"
    ]
  },
  "inject": {
    "headers": {
      "X-RFToken": "{{ credentials.accessToken }}"
    }
  },
  "experimental": true
}
