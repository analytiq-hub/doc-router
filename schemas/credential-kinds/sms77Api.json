{
  "key": "sms77Api",
  "display_name": "seven API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "title": "API Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": []
  },
  "inject": {
    "headers": {
      "X-Api-Key": "{{ credentials.apiKey }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "https://gateway.seven.io/api/hooks"
  }
}
