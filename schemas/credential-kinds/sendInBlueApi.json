{
  "key": "sendInBlueApi",
  "display_name": "Brevo",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "title": "API Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": []
  },
  "inject": {
    "headers": {
      "api-key": "{{ credentials.apiKey }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "https://api.brevo.com/v3/account"
  }
}
