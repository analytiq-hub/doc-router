{
  "key": "filescanApi",
  "display_name": "Filescan API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "title": "API Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": [
      "apiKey"
    ]
  },
  "inject": {
    "headers": {
      "X-Api-Key": "{{ credentials.apiKey }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "https://www.filescan.io/api/system/do-healthcheck"
  }
}
