{
  "key": "auth0ManagementApi",
  "display_name": "Auth0 Management API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "domain": {
        "title": "Auth0 Domain",
        "type": "string",
        "default": "your-domain.eu.auth0.com"
      },
      "clientId": {
        "title": "Client ID",
        "type": "string",
        "default": ""
      },
      "clientSecret": {
        "title": "Client Secret",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": [
      "clientId",
      "clientSecret",
      "domain"
    ]
  },
  "runtime_fields": [
    "sessionToken"
  ],
  "inject": {
    "headers": {
      "Authorization": "Bearer {{ credentials.sessionToken }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "=https://{{$credentials.domain}}/api/v2/clients"
  },
  "experimental": true
}
