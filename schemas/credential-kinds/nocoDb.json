{
  "key": "nocoDb",
  "display_name": "NocoDB",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiToken": {
        "title": "User Token",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "host": {
        "title": "Host",
        "type": "string",
        "default": ""
      }
    },
    "required": []
  },
  "inject": {
    "headers": {
      "xc-auth": "{{ credentials.apiToken }}"
    }
  },
  "experimental": true
}
