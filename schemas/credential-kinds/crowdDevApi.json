{
  "key": "crowdDevApi",
  "display_name": "crowd.dev API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "url": {
        "title": "URL",
        "type": "string",
        "default": "https://app.crowd.dev"
      },
      "tenantId": {
        "title": "Tenant ID",
        "type": "string",
        "default": ""
      },
      "token": {
        "title": "Token",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "allowUnauthorizedCerts": {
        "title": "Ignore SSL Issues (Insecure)",
        "type": "boolean",
        "description": "Whether to connect even if SSL certificate validation is not possible",
        "default": false
      }
    },
    "required": []
  },
  "inject": {
    "headers": {
      "Authorization": "{{\"Bearer \" + $credentials.token}}"
    }
  },
  "test_request": {
    "method": "POST",
    "url": "={{$credentials.url.replace(/\\/$/, \"\") + \"/api/tenant/\" + $credentials.tenantId}}/member/query"
  },
  "experimental": true
}
