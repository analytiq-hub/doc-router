{
  "key": "httpHeaderAuth",
  "display_name": "Header Auth",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "name",
      "value"
    ],
    "properties": {
      "name": {
        "type": "string",
        "title": "Header Name",
        "description": "e.g. Authorization"
      },
      "value": {
        "type": "string",
        "title": "Header Value",
        "x-secret": true,
        "description": "e.g. Bearer sk-…"
      }
    }
  },
  "inject": {
    "headers": {
      "{{ credentials.name }}": "{{ credentials.value }}"
    }
  },
  "experimental": false
}
