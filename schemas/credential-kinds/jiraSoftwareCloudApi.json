{
  "key": "jiraSoftwareCloudApi",
  "display_name": "Jira SW Cloud API",
  "auth_mode": "custom",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "email": {
        "title": "Email",
        "type": "string",
        "default": ""
      },
      "apiToken": {
        "title": "API Token",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "domain": {
        "title": "Domain",
        "type": "string",
        "default": ""
      }
    },
    "required": []
  },
  "test_request": {
    "method": "GET",
    "url": "={{$credentials?.domain}}/rest/api/2/project"
  },
  "experimental": true
}
