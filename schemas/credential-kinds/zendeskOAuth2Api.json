{
  "key": "zendeskOAuth2Api",
  "display_name": "Zendesk OAuth2 API",
  "auth_mode": "oauth2_authorization_code",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "subdomain": {
        "title": "Subdomain",
        "type": "string",
        "description": "The subdomain of your Zendesk work environment",
        "default": ""
      },
      "clientId": {
        "title": "Client ID",
        "type": "string",
        "default": ""
      },
      "clientSecret": {
        "title": "Client Secret",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": [
      "clientId",
      "clientSecret",
      "subdomain"
    ]
  },
  "extends": [
    "oAuth2Api"
  ],
  "runtime_fields": [
    "grantType",
    "authUrl",
    "accessTokenUrl",
    "scope",
    "authQueryParameters",
    "authentication"
  ],
  "experimental": true
}
