{
  "key": "koBoToolboxApi",
  "display_name": "KoBoToolbox API Token",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "URL": {
        "title": "API Root URL",
        "type": "string",
        "default": "https://kf.kobotoolbox.org/"
      },
      "token": {
        "title": "API Token",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": []
  },
  "inject": {
    "headers": {
      "Authorization": "Token {{ credentials.token }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "={{$credentials.URL}}/api/v2/assets/"
  },
  "experimental": true
}
