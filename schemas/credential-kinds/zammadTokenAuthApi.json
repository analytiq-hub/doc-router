{
  "key": "zammadTokenAuthApi",
  "display_name": "Zammad Token Auth API",
  "auth_mode": "custom",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "baseUrl": {
        "title": "Base URL",
        "type": "string",
        "default": ""
      },
      "accessToken": {
        "title": "Access Token",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "allowUnauthorizedCerts": {
        "title": "Ignore SSL Issues (Insecure)",
        "type": "boolean",
        "description": "Whether to connect even if SSL certificate validation is not possible",
        "default": false
      }
    },
    "required": [
      "accessToken",
      "baseUrl"
    ]
  },
  "experimental": true
}
