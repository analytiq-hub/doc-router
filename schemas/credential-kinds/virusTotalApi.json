{
  "key": "virusTotalApi",
  "display_name": "VirusTotal API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "accessToken": {
        "title": "API Token",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": [
      "accessToken"
    ]
  },
  "inject": {
    "headers": {
      "x-apikey": "{{ credentials.accessToken }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "https://www.virustotal.com/api/v3/popular_threat_categories"
  },
  "experimental": true
}
