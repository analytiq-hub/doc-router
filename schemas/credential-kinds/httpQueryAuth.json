{
  "key": "httpQueryAuth",
  "display_name": "Query Auth",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["name", "value"],
    "properties": {
      "name": {
        "type": "string",
        "title": "Parameter Name",
        "description": "e.g. api_key"
      },
      "value": {
        "type": "string",
        "title": "Parameter Value",
        "x-secret": true
      }
    }
  },
  "inject": {
    "query_params": {
      "{{ credentials.name }}": "{{ credentials.value }}"
    }
  }
}
