{
  "key": "ciscoUmbrellaApi",
  "display_name": "Cisco Umbrella API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "title": "API Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "secret": {
        "title": "Secret",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": [
      "apiKey",
      "secret"
    ]
  },
  "runtime_fields": [
    "sessionToken"
  ],
  "inject": {
    "headers": {
      "Authorization": "Bearer {{ credentials.sessionToken }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "https://api.umbrella.com/users"
  },
  "experimental": true
}
