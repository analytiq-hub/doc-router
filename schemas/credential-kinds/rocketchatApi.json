{
  "key": "rocketchatApi",
  "display_name": "Rocket API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "userId": {
        "title": "User ID",
        "type": "string",
        "default": ""
      },
      "authKey": {
        "title": "Auth Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "domain": {
        "title": "Domain",
        "type": "string",
        "default": ""
      }
    },
    "required": []
  },
  "inject": {
    "headers": {
      "X-Auth-Token": "{{ credentials.authKey }}",
      "X-User-Id": "{{ credentials.userId }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "={{$credentials.domain}}/api/v1/webdav.getMyAccounts"
  },
  "experimental": true
}
