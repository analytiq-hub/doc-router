{
  "key": "erpNextApi",
  "display_name": "ERPNext API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "title": "API Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "apiSecret": {
        "title": "API Secret",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "environment": {
        "title": "Environment",
        "type": "string",
        "enum": [
          "cloudHosted",
          "selfHosted"
        ],
        "default": "cloudHosted"
      },
      "subdomain": {
        "title": "Subdomain",
        "type": "string",
        "description": "Subdomain of cloud-hosted ERPNext instance. For example, \"n8n\" is the subdomain in: <code>https://n8n.erpnext.com</code>",
        "default": ""
      },
      "domain": {
        "title": "Domain",
        "type": "string",
        "description": "Fully qualified domain name of self-hosted ERPNext instance",
        "default": ""
      },
      "allowUnauthorizedCerts": {
        "title": "Ignore SSL Issues (Insecure)",
        "type": "boolean",
        "description": "Whether to connect even if SSL certificate validation is not possible",
        "default": false
      }
    },
    "required": []
  },
  "inject": {
    "headers": {
      "Authorization": "token {{ credentials.apiKey }}:{{ credentials.apiSecret }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "={{$credentials.environment === \"cloudHosted\" ? \"https://\" + $credentials.subdomain + \".\" + $credentials.domain : $credentials.domain}}/api/method/frappe.auth.get_logged_user"
  }
}
