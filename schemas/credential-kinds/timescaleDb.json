{
  "key": "timescaleDb",
  "display_name": "TimescaleDB",
  "auth_mode": "custom",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "host": {
        "title": "Host",
        "type": "string",
        "default": "localhost"
      },
      "database": {
        "title": "Database",
        "type": "string",
        "default": "postgres"
      },
      "user": {
        "title": "User",
        "type": "string",
        "default": "postgres"
      },
      "password": {
        "title": "Password",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "allowUnauthorizedCerts": {
        "title": "Ignore SSL Issues (Insecure)",
        "type": "boolean",
        "description": "Whether to connect even if SSL certificate validation is not possible",
        "default": false
      },
      "ssl": {
        "title": "SSL",
        "type": "string",
        "enum": [
          "allow",
          "disable",
          "require"
        ],
        "default": "disable"
      },
      "port": {
        "title": "Port",
        "type": "number",
        "default": 5432
      }
    },
    "required": []
  }
}
