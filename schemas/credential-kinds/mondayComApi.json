{
  "key": "mondayComApi",
  "display_name": "Monday.com API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiToken": {
        "title": "Token V2",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": []
  },
  "inject": {
    "headers": {
      "Authorization": "Bearer {{ credentials.apiToken }}"
    }
  },
  "test_request": {
    "method": "POST",
    "url": "https://api.monday.com/v2"
  },
  "experimental": true
}
