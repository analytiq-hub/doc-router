{
  "key": "matrixApi",
  "display_name": "Matrix API",
  "auth_mode": "custom",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "accessToken": {
        "title": "Access Token",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "homeserverUrl": {
        "title": "Homeserver URL",
        "type": "string",
        "default": "https://matrix-client.matrix.org"
      }
    },
    "required": []
  }
}
