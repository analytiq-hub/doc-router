{
  "key": "rundeckApi",
  "display_name": "Rundeck API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "url": {
        "title": "Url",
        "type": "string",
        "default": ""
      },
      "token": {
        "title": "Token",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": []
  },
  "inject": {
    "headers": {
      "user-agent": "n8n",
      "X-Rundeck-Auth-Token": "{{$credentials?.token}}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "={{$credentials.url}}/api/14/system/info"
  }
}
