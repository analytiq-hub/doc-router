{
  "key": "postmarkApi",
  "display_name": "Postmark API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "serverToken": {
        "title": "Server API Token",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": []
  },
  "inject": {
    "headers": {
      "X-Postmark-Server-Token": "{{ credentials.serverToken }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "https://api.postmarkapp.com/server"
  },
  "experimental": true
}
