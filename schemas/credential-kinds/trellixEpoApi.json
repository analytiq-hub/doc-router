{
  "key": "trellixEpoApi",
  "display_name": "Trellix (McAfee) ePolicy Orchestrator API",
  "auth_mode": "custom",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "username": {
        "title": "Username",
        "type": "string",
        "default": ""
      },
      "password": {
        "title": "Password",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": [
      "password",
      "username"
    ]
  }
}
