{
  "key": "elasticsearchApi",
  "display_name": "Elasticsearch API",
  "auth_mode": "custom",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "username": {
        "title": "Username",
        "type": "string",
        "default": ""
      },
      "password": {
        "title": "Password",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "baseUrl": {
        "title": "Base URL",
        "type": "string",
        "description": "Referred to as Elasticsearch 'endpoint' in the Elastic deployment dashboard",
        "default": ""
      },
      "ignoreSSLIssues": {
        "title": "Ignore SSL Issues (Insecure)",
        "type": "boolean",
        "default": false
      }
    },
    "required": []
  },
  "test_request": {
    "method": "GET",
    "url": "={{$credentials.baseUrl}}/_xpack?human=false"
  }
}
