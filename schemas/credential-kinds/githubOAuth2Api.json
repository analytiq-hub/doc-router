{
  "key": "githubOAuth2Api",
  "display_name": "GitHub OAuth2 API",
  "auth_mode": "oauth2_authorization_code",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "server": {
        "title": "Github Server",
        "type": "string",
        "description": "The server to connect to. Only has to be set if Github Enterprise is used.",
        "default": "https://api.github.com"
      }
    },
    "required": []
  },
  "extends": [
    "oAuth2Api"
  ],
  "runtime_fields": [
    "grantType",
    "authUrl",
    "accessTokenUrl",
    "scope",
    "authQueryParameters",
    "authentication"
  ],
  "experimental": true
}
