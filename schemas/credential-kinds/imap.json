{
  "key": "imap",
  "display_name": "IMAP",
  "auth_mode": "custom",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "user": {
        "title": "User",
        "type": "string",
        "default": ""
      },
      "password": {
        "title": "Password",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "host": {
        "title": "Host",
        "type": "string",
        "default": ""
      },
      "port": {
        "title": "Port",
        "type": "number",
        "default": 993
      },
      "secure": {
        "title": "SSL/TLS",
        "type": "boolean",
        "default": true
      },
      "allowUnauthorizedCerts": {
        "title": "Allow Self-Signed Certificates",
        "type": "boolean",
        "description": "Whether to connect even if SSL certificate validation is not possible",
        "default": false
      }
    },
    "required": []
  }
}
