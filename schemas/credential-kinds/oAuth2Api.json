{
  "key": "oAuth2Api",
  "display_name": "OAuth2 API",
  "auth_mode": "oauth2_authorization_code",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "grantType": {
        "title": "Grant Type",
        "type": "string",
        "enum": [
          "authorizationCode",
          "clientCredentials",
          "pkce"
        ],
        "default": "authorizationCode"
      },
      "authUrl": {
        "title": "Authorization URL",
        "type": "string",
        "default": ""
      },
      "accessTokenUrl": {
        "title": "Access Token URL",
        "type": "string",
        "default": ""
      },
      "clientId": {
        "title": "Client ID",
        "type": "string",
        "default": ""
      },
      "clientSecret": {
        "title": "Client Secret",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "scope": {
        "title": "Scope",
        "type": "string",
        "default": ""
      },
      "authQueryParameters": {
        "title": "Auth URI Query Parameters",
        "type": "string",
        "description": "For some services additional query parameters have to be set which can be defined here",
        "default": ""
      },
      "authentication": {
        "title": "Authentication",
        "type": "string",
        "enum": [
          "body",
          "header"
        ],
        "default": "body",
        "description": "How client ID and secret are sent to the token URL. Google and most providers use Body."
      },
      "ignoreSSLIssues": {
        "title": "Ignore SSL Issues (Insecure)",
        "type": "boolean",
        "default": false
      },
      "allowedHttpRequestDomains": {
        "title": "Allowed HTTP Request Domains",
        "type": "string",
        "enum": ["all", "domains", "none"],
        "default": "all",
        "x-ui-enum-names": ["All", "Specific Domains", "None"],
        "description": "Control which domains this credential can be used with in HTTP Request nodes"
      },
      "allowedDomains": {
        "title": "Allowed Domains",
        "type": "string",
        "default": "",
        "description": "Comma-separated list of allowed domains (supports wildcards with *)",
        "x-ui-show-when": {
          "field": "allowedHttpRequestDomains",
          "equals": "domains"
        }
      }
    },
    "required": [
      "accessTokenUrl",
      "authUrl",
      "clientId",
      "clientSecret"
    ]
  },
  "inject": {
    "headers": {
      "Authorization": "Bearer {{ credentials.oauthAccessToken }}"
    }
  },
  "runtime_fields": [
    "oauthAccessToken",
    "oauthRefreshToken",
    "oauthExpiresAt"
  ],
  "experimental": true
}
