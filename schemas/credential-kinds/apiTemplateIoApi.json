{
  "key": "apiTemplateIoApi",
  "display_name": "APITemplate.io API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "title": "API Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": []
  },
  "inject": {
    "headers": {
      "X-API-KEY": "{{ credentials.apiKey }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "https://api.apitemplate.io/v1/list-templates"
  },
  "experimental": true
}
