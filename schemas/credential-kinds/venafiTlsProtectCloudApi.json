{
  "key": "venafiTlsProtectCloudApi",
  "display_name": "Venafi TLS Protect Cloud",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "region": {
        "title": "Region",
        "type": "string",
        "enum": [
          "cloud",
          "eu"
        ],
        "default": "cloud"
      },
      "apiKey": {
        "title": "API Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": []
  },
  "inject": {
    "headers": {
      "tppl-api-key": "{{ credentials.apiKey }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "=https://api.venafi.{{$credentials.region ?? \"cloud\"}}/v1/preferences"
  }
}
