{
  "key": "microsoftOAuth2Api",
  "display_name": "Microsoft OAuth2 API",
  "auth_mode": "oauth2_authorization_code",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "grantType": {
        "type": "string",
        "default": "authorizationCode"
      },
      "authUrl": {
        "title": "Authorization URL",
        "type": "string",
        "default": "https://login.microsoftonline.com/common/oauth2/v2.0/authorize"
      },
      "accessTokenUrl": {
        "title": "Access Token URL",
        "type": "string",
        "default": "https://login.microsoftonline.com/common/oauth2/v2.0/token"
      },
      "authQueryParameters": {
        "type": "string",
        "default": "response_mode=query"
      },
      "authentication": {
        "type": "string",
        "default": "body"
      },
      "signInEmail": {
        "title": "Sign-in email (optional)",
        "type": "string",
        "description": "Microsoft account to pre-select when connecting (login_hint), e.g. user@tenant.onmicrosoft.com",
        "default": ""
      }
    },
    "required": []
  },
  "extends": [
    "oAuth2Api"
  ],
  "runtime_fields": [
    "grantType",
    "authQueryParameters",
    "authentication"
  ],
  "experimental": true
}
