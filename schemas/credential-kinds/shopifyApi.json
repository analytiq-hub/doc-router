{
  "key": "shopifyApi",
  "display_name": "Shopify API",
  "auth_mode": "custom",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "title": "API Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "password": {
        "title": "Password",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "shopSubdomain": {
        "title": "Shop Subdomain",
        "type": "string",
        "description": "Only the subdomain without .myshopify.com",
        "default": ""
      },
      "sharedSecret": {
        "title": "Shared Secret",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": [
      "apiKey",
      "password",
      "shopSubdomain"
    ]
  },
  "test_request": {
    "method": "GET",
    "url": "=https://{{$credentials.shopSubdomain}}.myshopify.com/admin/api/2024-07/products.json"
  }
}
