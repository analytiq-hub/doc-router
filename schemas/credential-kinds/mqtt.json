{
  "key": "mqtt",
  "display_name": "MQTT",
  "auth_mode": "custom",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "protocol": {
        "title": "Protocol",
        "type": "string",
        "enum": [
          "mqtt",
          "mqtts",
          "ws"
        ],
        "default": "mqtt"
      },
      "host": {
        "title": "Host",
        "type": "string",
        "default": ""
      },
      "port": {
        "title": "Port",
        "type": "number",
        "default": 1883
      },
      "username": {
        "title": "Username",
        "type": "string",
        "default": ""
      },
      "password": {
        "title": "Password",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "clean": {
        "title": "Clean Session",
        "type": "boolean",
        "description": "Whether to use clean session - set to false to receive QoS 1 and 2 messages while offline",
        "default": true
      },
      "clientId": {
        "title": "Client ID",
        "type": "string",
        "description": "Client ID. If left empty, one is autogenerated for you.",
        "default": ""
      },
      "ssl": {
        "title": "SSL",
        "type": "boolean",
        "default": false
      },
      "passwordless": {
        "title": "Passwordless",
        "type": "boolean",
        "description": "Whether to use passwordless connection with certificates (SASL mechanism EXTERNAL)",
        "default": true
      },
      "ca": {
        "title": "CA Certificates",
        "type": "string",
        "description": "SSL CA Certificates to use",
        "x-secret": true,
        "default": ""
      },
      "rejectUnauthorized": {
        "title": "Reject Unauthorized Certificate",
        "type": "boolean",
        "description": "Whether to validate Certificate",
        "default": false
      },
      "cert": {
        "title": "Client Certificate",
        "type": "string",
        "description": "SSL Client Certificate to use",
        "x-secret": true,
        "default": ""
      },
      "key": {
        "title": "Client Key",
        "type": "string",
        "description": "SSL Client Key to use",
        "x-secret": true,
        "default": ""
      }
    },
    "required": []
  }
}
