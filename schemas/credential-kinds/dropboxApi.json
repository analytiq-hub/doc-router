{
  "key": "dropboxApi",
  "display_name": "Dropbox API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "accessToken": {
        "title": "Access Token",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "accessType": {
        "title": "APP Access Type",
        "type": "string",
        "enum": [
          "folder",
          "full"
        ],
        "default": "full"
      }
    },
    "required": []
  },
  "inject": {
    "headers": {
      "Authorization": "Bearer {{ credentials.accessToken }}"
    }
  },
  "test_request": {
    "method": "POST",
    "url": "https://api.dropboxapi.com/2/users/get_current_account"
  }
}
