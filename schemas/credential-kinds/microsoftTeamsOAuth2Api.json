{
  "key": "microsoftTeamsOAuth2Api",
  "display_name": "Microsoft Teams OAuth2 API",
  "auth_mode": "oauth2_authorization_code",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "scope": {
        "type": "string",
        "default": "openid offline_access User.ReadWrite.All Group.ReadWrite.All Chat.ReadWrite",
        "description": "Default Teams Graph scopes; hidden from the form via runtime_fields."
      }
    },
    "required": []
  },
  "extends": [
    "microsoftOAuth2Api"
  ],
  "runtime_fields": [
    "scope"
  ],
  "test_request": {
    "method": "GET",
    "url": "https://graph.microsoft.com/v1.0/me"
  },
  "experimental": true
}
