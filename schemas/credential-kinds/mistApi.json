{
  "key": "mistApi",
  "display_name": "Mist API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "token": {
        "title": "API Token",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "region": {
        "title": "Region",
        "type": "string",
        "enum": [
          "eu",
          "global"
        ],
        "default": "eu"
      }
    },
    "required": [
      "token"
    ]
  },
  "inject": {
    "headers": {
      "Authorization": "Token {{ credentials.token }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "=https://api{{$credentials.region === \"eu\" ? \".eu\" : \"\"}}.mist.com/api/v1/self"
  }
}
