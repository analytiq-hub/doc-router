{
  "key": "googleAdsOAuth2Api",
  "display_name": "Google Ads OAuth2 API",
  "auth_mode": "oauth2_authorization_code",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "developerToken": {
        "title": "Developer Token",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "scope": {
        "type": "string",
        "default": "https://www.googleapis.com/auth/adwords",
        "description": "Default OAuth scopes for this Google service (hidden from the form via runtime_fields)."
      }
    },
    "required": [
      "developerToken"
    ]
  },
  "extends": [
    "googleOAuth2Api"
  ],
  "runtime_fields": [
    "scope"
  ],
  "experimental": true
}
