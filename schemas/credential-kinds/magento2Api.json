{
  "key": "magento2Api",
  "display_name": "Magento 2 API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "host": {
        "title": "Host",
        "type": "string",
        "default": ""
      },
      "accessToken": {
        "title": "Access Token",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": []
  },
  "inject": {
    "headers": {
      "Authorization": "Bearer {{ credentials.accessToken }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "={{$credentials.host}}/rest/default/V1/modules"
  }
}
