{
  "key": "grafanaApi",
  "display_name": "Grafana API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "title": "API Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "baseUrl": {
        "title": "Base URL",
        "type": "string",
        "description": "Base URL of your Grafana instance",
        "default": ""
      }
    },
    "required": [
      "apiKey",
      "baseUrl"
    ]
  },
  "inject": {
    "headers": {
      "Authorization": "Bearer {{ credentials.apiKey }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "={{$credentials.baseUrl.replace(new RegExp(\"/$\"), \"\") + \"/api\" }}/folders"
  },
  "experimental": true
}
