{
  "key": "taigaApi",
  "display_name": "Taiga API",
  "auth_mode": "custom",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "username": {
        "title": "Username",
        "type": "string",
        "default": ""
      },
      "password": {
        "title": "Password",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "environment": {
        "title": "Environment",
        "type": "string",
        "enum": [
          "cloud",
          "selfHosted"
        ],
        "default": "cloud"
      },
      "url": {
        "title": "URL",
        "type": "string",
        "default": ""
      }
    },
    "required": []
  },
  "experimental": true
}
