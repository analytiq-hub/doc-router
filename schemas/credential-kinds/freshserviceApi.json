{
  "key": "freshserviceApi",
  "display_name": "Freshservice API",
  "auth_mode": "custom",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "title": "API Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "domain": {
        "title": "Domain",
        "type": "string",
        "description": "Domain in the Freshservice org URL. For example, in <code>https://n8n.freshservice.com</code>, the domain is <code>n8n</code>",
        "default": ""
      }
    },
    "required": []
  },
  "experimental": true
}
