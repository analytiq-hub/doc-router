{
  "key": "mailjetSmsApi",
  "display_name": "Mailjet SMS API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "token": {
        "title": "Token",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": []
  },
  "inject": {
    "headers": {
      "Authorization": "Bearer {{ credentials.token }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "https://api.mailjet.com/v4/sms"
  }
}
