{
  "key": "fortiGateApi",
  "display_name": "Fortinet FortiGate API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "accessToken": {
        "title": "Access Token",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": [
      "accessToken"
    ]
  },
  "inject": {
    "query_params": {
      "access_token": "{{ credentials.accessToken }}"
    }
  }
}
