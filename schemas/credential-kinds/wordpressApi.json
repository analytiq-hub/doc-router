{
  "key": "wordpressApi",
  "display_name": "Wordpress API",
  "auth_mode": "custom",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "username": {
        "title": "Username",
        "type": "string",
        "default": ""
      },
      "password": {
        "title": "Password",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "url": {
        "title": "Wordpress URL",
        "type": "string",
        "default": ""
      },
      "allowUnauthorizedCerts": {
        "title": "Ignore SSL Issues (Insecure)",
        "type": "boolean",
        "description": "Whether to connect even if SSL certificate validation is not possible",
        "default": false
      }
    },
    "required": []
  },
  "test_request": {
    "method": "GET",
    "url": "={{$credentials?.url}}/wp-json/wp/v2/users"
  },
  "experimental": true
}
