{
  "key": "mispApi",
  "display_name": "MISP API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "title": "API Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "baseUrl": {
        "title": "Base URL",
        "type": "string",
        "default": ""
      },
      "allowUnauthorizedCerts": {
        "title": "Allow Unauthorized Certificates",
        "type": "boolean",
        "description": "Whether to connect even if SSL certificate validation is not possible",
        "default": false
      }
    },
    "required": []
  },
  "inject": {
    "headers": {
      "Authorization": "{{ credentials.apiKey }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "={{$credentials.baseUrl.replace(new RegExp(\"/$\"), \"\")}}/tags"
  }
}
