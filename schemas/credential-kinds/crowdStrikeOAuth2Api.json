{
  "key": "crowdStrikeOAuth2Api",
  "display_name": "CrowdStrike OAuth2 API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "url": {
        "title": "URL",
        "type": "string",
        "default": ""
      },
      "clientId": {
        "title": "Client ID",
        "type": "string",
        "default": ""
      },
      "clientSecret": {
        "title": "Client Secret",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": [
      "clientId",
      "clientSecret",
      "url"
    ]
  },
  "runtime_fields": [
    "sessionToken"
  ],
  "inject": {
    "headers": {
      "Authorization": "Bearer {{ credentials.sessionToken }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "={{$credentials?.url}}/user-management/queries/users/v1"
  }
}
