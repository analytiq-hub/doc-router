{
  "key": "deepLApi",
  "display_name": "DeepL API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "title": "API Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "apiPlan": {
        "title": "API Plan",
        "type": "string",
        "enum": [
          "pro",
          "free"
        ],
        "default": "pro"
      }
    },
    "required": []
  },
  "inject": {
    "query_params": {
      "auth_key": "{{ credentials.apiKey }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "={{$credentials.apiPlan === \"pro\" ? \"https://api.deepl.com/v2\" : \"https://api-free.deepl.com/v2\" }}/usage"
  }
}
