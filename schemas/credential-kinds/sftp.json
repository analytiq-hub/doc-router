{
  "key": "sftp",
  "display_name": "SFTP",
  "auth_mode": "custom",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "host": {
        "title": "Host",
        "type": "string",
        "default": ""
      },
      "port": {
        "title": "Port",
        "type": "number",
        "default": 22
      },
      "username": {
        "title": "Username",
        "type": "string",
        "default": ""
      },
      "password": {
        "title": "Password",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "privateKey": {
        "title": "Private Key",
        "type": "string",
        "description": "String that contains a private key for either key-based or hostbased user authentication (OpenSSH format)",
        "x-secret": true,
        "default": ""
      },
      "passphrase": {
        "title": "Passphrase",
        "type": "string",
        "description": "For an encrypted private key, this is the passphrase used to decrypt it",
        "x-secret": true,
        "default": ""
      }
    },
    "required": [
      "host",
      "port",
      "username"
    ]
  },
  "experimental": true
}
