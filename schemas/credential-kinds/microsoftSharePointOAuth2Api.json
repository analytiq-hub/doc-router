{
  "key": "microsoftSharePointOAuth2Api",
  "display_name": "Microsoft SharePoint OAuth2 API",
  "auth_mode": "oauth2_authorization_code",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "scope": {
        "type": "string",
        "default": "openid offline_access https://{{subdomain}}.sharepoint.com/.default",
        "description": "SharePoint resource scope; {{subdomain}} is replaced from the Subdomain field when connecting."
      },
      "subdomain": {
        "title": "Subdomain",
        "type": "string",
        "default": "",
        "description": "Tenant slug from your SharePoint URL (e.g. tenant123 in https://tenant123.sharepoint.com). Required for OAuth scope and REST API host.",
        "x-ui-placeholder": "e.g. tenant123"
      }
    },
    "required": []
  },
  "extends": [
    "microsoftOAuth2Api"
  ],
  "runtime_fields": [
    "scope"
  ],
  "test_request": {
    "method": "GET",
    "url": "https://{{ credentials.subdomain }}.sharepoint.com/_api/v2.0/sites/root"
  },
  "experimental": true
}
