{
  "key": "odooApi",
  "display_name": "Odoo API",
  "auth_mode": "custom",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "url": {
        "title": "Site URL",
        "type": "string",
        "default": ""
      },
      "username": {
        "title": "Username",
        "type": "string",
        "default": ""
      },
      "password": {
        "title": "Password or API Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "db": {
        "title": "Database Name",
        "type": "string",
        "default": ""
      }
    },
    "required": [
      "password",
      "url",
      "username"
    ]
  }
}
