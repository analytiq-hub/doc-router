{
  "key": "dropboxOAuth2Api",
  "display_name": "Dropbox OAuth2 API",
  "auth_mode": "oauth2_authorization_code",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "accessType": {
        "title": "APP Access Type",
        "type": "string",
        "enum": [
          "folder",
          "full"
        ],
        "default": "full"
      }
    },
    "required": []
  },
  "extends": [
    "oAuth2Api"
  ],
  "runtime_fields": [
    "grantType",
    "authUrl",
    "accessTokenUrl",
    "scope",
    "authQueryParameters",
    "authentication"
  ],
  "experimental": true
}
