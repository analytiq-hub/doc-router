{
  "key": "zscalerZiaApi",
  "display_name": "Zscaler ZIA API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "baseUrl": {
        "title": "Base URL",
        "type": "string",
        "default": ""
      },
      "username": {
        "title": "Username",
        "type": "string",
        "default": ""
      },
      "password": {
        "title": "Password",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "apiKey": {
        "title": "Api Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": [
      "apiKey",
      "baseUrl",
      "password",
      "username"
    ]
  },
  "runtime_fields": [
    "cookie"
  ],
  "inject": {
    "headers": {
      "Cookie": "{{ credentials.cookie }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "=https://{{$credentials.baseUrl}}/api/v1/authSettings/exemptedUrls"
  }
}
