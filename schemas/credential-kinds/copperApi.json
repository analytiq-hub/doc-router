{
  "key": "copperApi",
  "display_name": "Copper API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "title": "API Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "email": {
        "title": "Email",
        "type": "string",
        "default": ""
      }
    },
    "required": [
      "apiKey",
      "email"
    ]
  },
  "inject": {
    "headers": {
      "X-PW-AccessToken": "{{ credentials.apiKey }}",
      "X-PW-Application": "developer_api",
      "X-PW-UserEmail": "{{ credentials.email }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "https://api.copper.com/developer_api/v1/users/me"
  }
}
