{
  "key": "oktaApi",
  "display_name": "Okta API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "url": {
        "title": "URL",
        "type": "string",
        "default": ""
      },
      "accessToken": {
        "title": "Access Token",
        "type": "string",
        "description": "Secure Session Web Service Access Token",
        "x-secret": true,
        "default": ""
      }
    },
    "required": [
      "accessToken",
      "url"
    ]
  },
  "inject": {
    "headers": {
      "Authorization": "SSWS {{ credentials.accessToken }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "={{$credentials.url}}/api/v1/api-tokens"
  }
}
