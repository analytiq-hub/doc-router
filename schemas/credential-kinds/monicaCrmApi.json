{
  "key": "monicaCrmApi",
  "display_name": "Monica CRM API",
  "auth_mode": "custom",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "environment": {
        "title": "Environment",
        "type": "string",
        "enum": [
          "cloudHosted",
          "selfHosted"
        ],
        "default": "cloudHosted"
      },
      "domain": {
        "title": "Self-Hosted Domain",
        "type": "string",
        "default": ""
      },
      "apiToken": {
        "title": "API Token",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": []
  },
  "experimental": true
}
