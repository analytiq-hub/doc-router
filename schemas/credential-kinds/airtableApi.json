{
  "key": "airtableApi",
  "display_name": "Airtable API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "title": "API Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": []
  },
  "inject": {
    "query_params": {
      "api_key": "{{ credentials.apiKey }}"
    }
  }
}
