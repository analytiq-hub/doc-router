{
  "key": "highLevelApi",
  "display_name": "HighLevel API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "title": "API Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": []
  },
  "inject": {
    "headers": {
      "Authorization": "Bearer {{ credentials.apiKey }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "https://rest.gohighlevel.com/v1/custom-values/"
  }
}
