{
  "key": "kibanaApi",
  "display_name": "Kibana API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "url": {
        "title": "URL",
        "type": "string",
        "default": ""
      },
      "username": {
        "title": "Username",
        "type": "string",
        "default": ""
      },
      "password": {
        "title": "Password",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": [
      "password",
      "url",
      "username"
    ]
  },
  "inject": {
    "headers": {
      "kbn-xsrf": "True"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "={{$credentials.url}}/api/features"
  },
  "experimental": true
}
