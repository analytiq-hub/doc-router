{
  "key": "iterableApi",
  "display_name": "Iterable API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "title": "API Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "region": {
        "title": "Region",
        "type": "string",
        "enum": [
          "https://api.eu.iterable.com",
          "https://api.iterable.com"
        ],
        "default": "https://api.iterable.com"
      }
    },
    "required": []
  },
  "inject": {
    "headers": {
      "Api_Key": "{{ credentials.apiKey }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "={{$credentials?.region}}/api/webhooks"
  },
  "experimental": true
}
