{
  "key": "formIoApi",
  "display_name": "Form.io API",
  "auth_mode": "custom",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "environment": {
        "title": "Environment",
        "type": "string",
        "enum": [
          "cloudHosted",
          "selfHosted"
        ],
        "default": "cloudHosted"
      },
      "domain": {
        "title": "Self-Hosted Domain",
        "type": "string",
        "default": ""
      },
      "email": {
        "title": "Email",
        "type": "string",
        "default": ""
      },
      "password": {
        "title": "Password",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": []
  }
}
