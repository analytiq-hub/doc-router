{
  "key": "wekanApi",
  "display_name": "Wekan API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "username": {
        "title": "Username",
        "type": "string",
        "default": ""
      },
      "password": {
        "title": "Password",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "url": {
        "title": "URL",
        "type": "string",
        "default": ""
      }
    },
    "required": []
  },
  "runtime_fields": [
    "token"
  ],
  "inject": {
    "headers": {
      "Authorization": "Bearer {{ credentials.token }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "={{$credentials.url.replace(new RegExp(\"/$\"), \"\")}}/api/user"
  },
  "experimental": true
}
