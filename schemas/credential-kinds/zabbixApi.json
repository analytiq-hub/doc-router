{
  "key": "zabbixApi",
  "display_name": "Zabbix API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "url": {
        "title": "URL",
        "type": "string",
        "default": ""
      },
      "apiToken": {
        "title": "API Token",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": [
      "apiToken",
      "url"
    ]
  },
  "inject": {
    "headers": {
      "Authorization": "Bearer {{ credentials.apiToken }}",
      "Content-Type": "application/json-rpc"
    }
  },
  "test_request": {
    "method": "POST",
    "url": "={{$credentials.url}}/api_jsonrpc.php"
  }
}
