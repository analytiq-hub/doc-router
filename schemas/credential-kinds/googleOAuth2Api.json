{
  "key": "googleOAuth2Api",
  "display_name": "Google OAuth2 API",
  "auth_mode": "oauth2_authorization_code",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "grantType": {
        "type": "string",
        "default": "authorizationCode"
      },
      "authUrl": {
        "type": "string",
        "default": "https://accounts.google.com/o/oauth2/v2/auth"
      },
      "accessTokenUrl": {
        "type": "string",
        "default": "https://oauth2.googleapis.com/token"
      },
      "authQueryParameters": {
        "type": "string",
        "default": "{\"access_type\":\"offline\",\"prompt\":\"consent\"}"
      },
      "authentication": {
        "type": "string",
        "default": "body"
      },
      "ignoreSSLIssues": {
        "type": "boolean",
        "default": false,
        "x-ui-hidden": true
      }
    },
    "required": []
  },
  "extends": [
    "oAuth2Api"
  ],
  "runtime_fields": [
    "grantType",
    "authUrl",
    "accessTokenUrl",
    "authQueryParameters",
    "authentication"
  ],
  "experimental": true
}
