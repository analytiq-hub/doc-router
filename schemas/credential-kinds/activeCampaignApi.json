{
  "key": "activeCampaignApi",
  "display_name": "ActiveCampaign API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiUrl": {
        "title": "API URL",
        "type": "string",
        "default": ""
      },
      "apiKey": {
        "title": "API Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": []
  },
  "inject": {
    "headers": {
      "Api-Token": "{{ credentials.apiKey }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "={{$credentials.apiUrl}}/api/3/fields"
  }
}
