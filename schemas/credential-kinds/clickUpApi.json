{
  "key": "clickUpApi",
  "display_name": "ClickUp API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "accessToken": {
        "title": "Access Token",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": []
  },
  "inject": {
    "headers": {
      "Authorization": "{{ credentials.accessToken }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "https://api.clickup.com/api/v2/team"
  }
}
