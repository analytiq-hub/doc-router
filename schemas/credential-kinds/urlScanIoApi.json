{
  "key": "urlScanIoApi",
  "display_name": "urlscan.io API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "title": "API Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": [
      "apiKey"
    ]
  },
  "inject": {
    "headers": {
      "API-KEY": "{{ credentials.apiKey }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "https://urlscan.io/user/quotas"
  },
  "experimental": true
}
