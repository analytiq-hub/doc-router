{
  "key": "whatsAppApi",
  "display_name": "WhatsApp API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "accessToken": {
        "title": "Access Token",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "businessAccountId": {
        "title": "Business Account ID",
        "type": "string",
        "default": ""
      }
    },
    "required": [
      "accessToken",
      "businessAccountId"
    ]
  },
  "inject": {
    "headers": {
      "Authorization": "Bearer {{ credentials.accessToken }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "https://graph.facebook.com/v13.0/"
  }
}
