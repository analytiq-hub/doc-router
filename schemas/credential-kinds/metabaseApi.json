{
  "key": "metabaseApi",
  "display_name": "Metabase API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "url": {
        "title": "URL",
        "type": "string",
        "default": ""
      },
      "username": {
        "title": "Username",
        "type": "string",
        "default": ""
      },
      "password": {
        "title": "Password",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": []
  },
  "runtime_fields": [
    "sessionToken"
  ],
  "inject": {
    "headers": {
      "X-Metabase-Session": "{{ credentials.sessionToken }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "={{$credentials?.url}}/api/user/current"
  },
  "experimental": true
}
