{
  "key": "twakeCloudApi",
  "display_name": "Twake Cloud API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "workspaceKey": {
        "title": "Workspace Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": []
  },
  "inject": {
    "headers": {
      "Authorization": "Bearer {{ credentials.workspaceKey }}"
    }
  },
  "test_request": {
    "method": "POST",
    "url": "https://plugins.twake.app/plugins/n8n/channel"
  },
  "experimental": true
}
