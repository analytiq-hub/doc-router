{
  "key": "ghostContentApi",
  "display_name": "Ghost Content API",
  "auth_mode": "custom",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "url": {
        "title": "URL",
        "type": "string",
        "default": ""
      },
      "apiKey": {
        "title": "API Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": []
  },
  "test_request": {
    "method": "GET",
    "url": "={{$credentials.url}}/ghost/api/v3/content/settings/"
  }
}
