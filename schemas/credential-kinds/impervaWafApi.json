{
  "key": "impervaWafApi",
  "display_name": "Imperva WAF API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiID": {
        "title": "API ID",
        "type": "string",
        "default": ""
      },
      "apiKey": {
        "title": "API Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": [
      "apiID",
      "apiKey"
    ]
  },
  "inject": {
    "headers": {
      "x-API-Id": "{{ credentials.apiID }}",
      "x-API-Key": "{{ credentials.apiKey }}"
    }
  },
  "experimental": true
}
