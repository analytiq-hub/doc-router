{
  "key": "gongApi",
  "display_name": "Gong API",
  "auth_mode": "custom",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "baseUrl": {
        "title": "Base URL",
        "type": "string",
        "default": "https://api.gong.io"
      },
      "accessKey": {
        "title": "Access Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "accessKeySecret": {
        "title": "Access Key Secret",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": []
  },
  "test_request": {
    "method": "GET",
    "url": "={{ $credentials.baseUrl.replace(new RegExp(\"/$\"), \"\") }}/v2/users"
  },
  "experimental": true
}
