{
  "key": "cloudflareApi",
  "display_name": "Cloudflare API",
  "auth_mode": "api_key",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiToken": {
        "title": "API Token",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": []
  },
  "inject": {
    "headers": {
      "Authorization": "Bearer {{ credentials.apiToken }}"
    }
  },
  "test_request": {
    "method": "GET",
    "url": "https://api.cloudflare.com/client/v4/user/tokens/verify"
  }
}
