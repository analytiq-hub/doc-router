{
  "key": "mailgunApi",
  "display_name": "Mailgun API",
  "auth_mode": "custom",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiDomain": {
        "title": "API Domain",
        "type": "string",
        "enum": [
          "api.eu.mailgun.net",
          "api.mailgun.net"
        ],
        "description": "The configured mailgun API domain",
        "default": "api.mailgun.net"
      },
      "emailDomain": {
        "title": "Email Domain",
        "type": "string",
        "default": ""
      },
      "apiKey": {
        "title": "API Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      }
    },
    "required": []
  },
  "test_request": {
    "method": "GET",
    "url": "=https://{{$credentials.apiDomain}}/v3/domains"
  },
  "experimental": true
}
