{
  "key": "mailjetEmailApi",
  "display_name": "Mailjet Email API",
  "auth_mode": "custom",
  "secret_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "title": "API Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "secretKey": {
        "title": "Secret Key",
        "type": "string",
        "x-secret": true,
        "default": ""
      },
      "sandboxMode": {
        "title": "Sandbox Mode",
        "type": "boolean",
        "description": "Whether to allow to run the API call in a Sandbox mode, where all validations of the payload will be done without delivering the message",
        "default": false
      }
    },
    "required": []
  },
  "test_request": {
    "method": "GET",
    "url": "https://api.mailjet.com/v3/REST/template"
  },
  "experimental": true
}
